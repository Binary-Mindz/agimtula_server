model Invoice {
    id                    String            @id @unique() @default(uuid())
    invoiceNo             String            @unique()
    issueDate             DateTime
    dueDate               DateTime?
    type                  InvoiceClientType
    companyName           String // client or companyName
    email                 String
    AddressAndContactInfo String?
    projectInformation    String?
    projectDescription    String?

    serviceAndItems ServiceAndItem[]
    tax             Float
    subTotal        Float
    totalAmount     Float

    mobilePaymentLink String?

    additionalNote String?
    businessDatas  BusinessData[]

    createdAt DateTime @default(now())
}

model BusinessData {
    id              String @id @unique @default(uuid())
    businessIdLabel String
    businessIdValue String

    invoiceId String
    invoice   Invoice @relation(fields: [invoiceId], references: [id])
}

model ServiceAndItem {
    id          String @id @unique() @default(uuid())
    description String
    qty         Int    @default(1)
    rate        Float
    totalAmount Float

    invoice   Invoice @relation(fields: [invoiceId], references: [id])
    invoiceId String
}

enum InvoiceClientType {
    CLIENT
    BUSINESS
}
