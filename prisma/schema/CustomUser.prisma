model CustomUser{
    id              String  @unique    @id @default(uuid())
    fullName        String
    email           String  @unique
    phoneNumber     String?
    companyName     String?
    address         String?
    userRole        String
    accountStatus   Boolean  @default(true) 
    status          CustomUserStatus @default(ACTIVE)

    subscriptionPlan String?
    password String

    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@map("custom_user")
}

enum CustomUserStatus {
    ACTIVE
    INACTIVE
    SUSPENDED
}

enum CustomUserRole {
  ADMIN
  USER
  ACCOUNTANT
}