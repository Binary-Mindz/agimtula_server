# Tink Bank Integration Environment Variables
# ⚠️ IMPORTANT: Get these from https://console.tink.com
# NEVER commit TINK_CLIENT_SECRET to version control!

# Your Tink Client ID from Console
# Find it at: https://console.tink.com → Your App → Client ID
TINK_CLIENT_ID=your_client_id_from_console

# Your Tink Client Secret from Console
# Find it at: https://console.tink.com → Your App → Client Secret
# ⚠️ Keep this SECRET! Never commit to git!
TINK_CLIENT_SECRET=your_client_secret_from_console

# Redirect URI (must match exactly in Tink Console)
# After bank authentication, user will be redirected here
# Local development:
TINK_REDIRECT_URI=http://localhost:3001/tink/callback

# Production example:
# TINK_REDIRECT_URI=https://yourdomain.com/tink/callback

# Optional: Tink API URL (default: https://api.tink.com)
# TINK_API_URL=https://api.tink.com

# Optional: Node environment
NODE_ENV=development