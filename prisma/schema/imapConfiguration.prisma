model imapConfiguration {
    id       String  @id @unique @default(uuid())
    userId   String  @unique
    host     String
    port     Int
    username String
    password String
    secure   Boolean @default(true)

    // relations
    user User @relation(fields: [userId], references: [id])

    // subscription plan details
    userSubscriptionPlan userSubscriptionPlan?

    startedAt DateTime @default(now())
    expiredAt DateTime

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@map("imap_configuration")
}

// user relation with subscription plan based on their selected plan
model userSubscriptionPlan {
    id String @id @unique @default(uuid())

    UserId String @unique
    user   User   @relation(fields: [UserId], references: [id])

    imapConfigurationId String            @unique
    imapConfiguration   imapConfiguration @relation(fields: [imapConfigurationId], references: [id])

    isLimitedInvoicePerMonth Boolean
    perMonthInvoiceCount     Int
    realtimeImapChecking     Int // in seconds

    price         Float
    setupFee      Float @default(0.00)
    freeTrialDays Int?

    startedAt DateTime @default(now())
    expiredAt DateTime

    createdAt DateTime @default(now())

    @@map("user_subscription_plan")
}

// user relation with subscription plan based on historyand previous plans 
model userSubscriptionPlanHistory {
    id String @id @unique @default(uuid())

    UserId String
    user   User   @relation(fields: [UserId], references: [id])

    isLimitedInvoicePerMonth Boolean
    perMonthInvoiceCount     Int

    realtimeImapChecking Int

    price         Float
    setupFee      Float @default(0.00)
    freeTrialDays Int?

    billingPeriod BillingPeriod

    startedAt DateTime @default(now())
    expiredAt DateTime

    createdAt DateTime @default(now())

    @@map("userSubscriptionPlan")
}
