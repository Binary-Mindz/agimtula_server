model Invoice {
    id                    String            @id @unique() @default(uuid())
    invoiceNo             String            @unique()
    userId                String
    imapConfigurationId   String?
    issueDate             DateTime
    dueDate               DateTime?
    type                  InvoiceClientType
    companyName           String // client or companyName
    email                 String
    AddressAndContactInfo String?
    projectInformation    String?
    projectDescription    String?

    serviceAndItems ServiceAndItem[]
    vat             Float
    subTotal        Float
    totalAmount     Float

    isPaid                Boolean   @default(false)
    paidAt                DateTime?
    stripeSessionId       String?
    stripePaymentIntentId String?

    additionalNote String?
    businessDatas  BusinessData[]
    vendor         String?

    invoiceSource  InvoiceSource @default(MANUAL)
    haveAttachment Boolean       @default(false)
    attachmentUrl  String?

    isDrafted             Boolean @default(false)
    previewedByAccountant Boolean @default(false)

    createdAt DateTime @default(now())
}

model BusinessData {
    id              String @id @unique @default(uuid())
    businessIdLabel String
    businessIdValue String

    invoiceId String
    invoice   Invoice @relation(fields: [invoiceId], references: [id])
}

model ServiceAndItem {
    id          String @id @unique() @default(uuid())
    description String
    qty         Int    @default(1)
    rate        Float
    totalAmount Float

    invoice   Invoice @relation(fields: [invoiceId], references: [id])
    invoiceId String
}

enum InvoiceClientType {
    CLIENT
    BUSINESS
}

enum InvoiceSource {
    MANUAL
    EMAIL
}
