model ActivityLog {
  id String @id @default(uuid())

  userId    String?
  userName  String?
  userEmail String?

  type        String
  title       String
  description String?

  amount   Float?
  currency String?

  category String
  level    String @default("INFO")

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([category])
  @@index([level])
  @@index([createdAt])
  @@map("activity_logs")
}
